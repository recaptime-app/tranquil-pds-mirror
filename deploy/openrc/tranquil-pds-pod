#!/sbin/openrc-run

name="tranquil-pds-pod"
description="Tranquil PDS podman pod"

depend() {
    need net
    after firewall
}

start() {
    ebegin "Creating ${name}"
    podman pod exists tranquil-pds || \
        podman pod create --name tranquil-pds \
            --publish 80:80 \
            --publish 443:443
    eend $?
}

stop() {
    ebegin "Removing ${name}"
    podman pod rm -f tranquil-pds
    eend $?
}
